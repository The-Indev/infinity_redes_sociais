# Substituídos no entrypoint do container em runtime (envsubst em /usr/share/nginx/html/env.js).
# No modo dev (npm run dev), o Vite também lê estas variáveis se prefixadas com VITE_.

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SCHEMA=infinity_redes_sociais
WEBHOOK_APROVACAO=https://n8n.infinitydev.tech/webhook/aprovacao
WEBHOOK_IMAGEM=https://n8n.space-cloud.tech/webhook/imagem
WEBHOOK_COLETOR=https://n8n.infinitydev.tech/webhook/coletor

# URL do video-service que o NAVEGADOR chama.
#  - VAZIO  -> mesma origem: o nginx faz proxy de /api/ (imagem única EasyPanel).
#  - dev / docker-compose de 2 serviços -> http://localhost:3001
# No EasyPanel (Dockerfile.easypanel) deixe esta variável VAZIA/não definida.
VIDEO_SERVICE_URL=http://localhost:3001

# --- video-service (microserviço ffmpeg) ---
# Use a service_role key (upload no Storage + update sem esbarrar em RLS).
SUPABASE_SERVICE_KEY=eyJhbGciOi...
SUPABASE_VIDEO_BUCKET=videos
SUPABASE_TABELA=posts_gerados
SUPABASE_COLUNA_VIDEO=url_video_gerado
DURACAO_PADRAO=30

# Variantes VITE_ para uso em dev local (npm run dev)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
VITE_SUPABASE_SCHEMA=infinity_redes_sociais
VITE_WEBHOOK_APROVACAO=https://n8n.infinitydev.tech/webhook/aprovacao
VITE_WEBHOOK_IMAGEM=https://n8n.space-cloud.tech/webhook/imagem
VITE_WEBHOOK_COLETOR=https://n8n.infinitydev.tech/webhook/coletor
VITE_VIDEO_SERVICE_URL=http://localhost:3001

# IMPORTANTE:
# 1. O schema "infinity_redes_sociais" precisa estar exposto no Postgrest
#    (Supabase Dashboard → Settings → API → Exposed schemas).
# 2. A tabela posts_gerados precisa ter as colunas adicionais:
#       - url_imagem_gerada text       (URL pública do Storage)
#       - status_aprovacao smallint NOT NULL DEFAULT 0
#       (0=pendente, 1=aprovado, 2=reprovado)
# 3. O bucket de Storage onde a imagem é salva deve ser público
#    (ou trocar imagem_url por path + uso de signed URLs).
# 4. Para o vídeo:
#       - Criar o bucket "videos" (público) no Supabase Storage.
#       - Adicionar a coluna: url_video_gerado text  (na tabela posts_gerados).
#       - O video-service usa SUPABASE_SERVICE_KEY (service_role) p/ upload+update.
